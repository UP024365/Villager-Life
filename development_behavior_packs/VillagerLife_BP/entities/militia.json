      },
      "minecraft:attack": { "damage": 6 },
      "minecraft:behavior.random_stroll": { "priority": 3, "speed_multiplier": 1.0 },
      "minecraft:behavior.look_at_player": { "priority": 4, "look_distance": 6.0, "probability": 0.02 }
    }
  }
