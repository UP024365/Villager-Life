{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "custom:militia",
      "materials": { "default": "entity_alphatest" },
      "textures": { "default": "textures/entity/militia" },
      "geometry": { "default": "geometry.humanoid.custom" },
      "animations": {
        "move": "animation.humanoid.walk",
        "idle": "animation.humanoid.idle",
        "attack": "animation.humanoid.attack"
      },
      "scripts": {
        "animate": [
          "idle",
          { "move": "query.modified_move_speed > 0.1" },
          { "attack": "query.is_attacking" }
        ]
      },
      "render_controllers": [ "controller.render.default" ],
      "spawn_egg": { "texture": "spawn_egg", "texture_index": 20 }
    }
  }
}